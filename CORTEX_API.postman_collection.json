{
  "info": {
    "name": "CORTEX CMMS API",
    "description": "Complete API collection for CORTEX Maintenance Management System (Multi-Tenant)\n\nConnected to Supabase PostgreSQL with RLS.\n\n⚠️ IMPORTANT — All login/register requests require either `subdomain` or `tenant_id` to identify the tenant. The test scripts automatically save the token and tenant_id as collection variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://cortex-api.onrender.com/api",
      "type": "string"
    },
    {
      "key": "local_url",
      "value": "http://localhost:8000/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "tenant_id",
      "value": "",
      "type": "string",
      "description": "Auto-set by Login / Register test scripts"
    },
    {
      "key": "subdomain",
      "value": "acme",
      "type": "string",
      "description": "Tenant subdomain — change to match your tenant"
    }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Registration successful', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Save token & tenant', function () {",
                  "    var response = pm.response.json();",
                  "    if (response.data && response.data.token) {",
                  "        pm.collectionVariables.set('token', response.data.token);",
                  "        console.log('Token saved from registration');",
                  "    }",
                  "    if (response.data && response.data.tenant) {",
                  "        pm.collectionVariables.set('tenant_id', response.data.tenant.id);",
                  "        console.log('Tenant ID saved: ' + response.data.tenant.id);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"subdomain\": \"{{subdomain}}\",\n    \"username\": \"jdoe\",\n    \"email\": \"jdoe@cortex.com\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\",\n    \"first_name\": \"John\",\n    \"last_name\": \"Doe\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login successful', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Save token & tenant', function () {",
                  "    var response = pm.response.json();",
                  "    if (response.data && response.data.token) {",
                  "        pm.collectionVariables.set('token', response.data.token);",
                  "        console.log('Token saved successfully');",
                  "    }",
                  "    if (response.data && response.data.tenant) {",
                  "        pm.collectionVariables.set('tenant_id', response.data.tenant.id);",
                  "        pm.collectionVariables.set('subdomain', response.data.tenant.subdomain);",
                  "        console.log('Tenant saved: ' + response.data.tenant.subdomain);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"admin@cortex.com\",\n    \"password\": \"password123\",\n    \"subdomain\": \"{{subdomain}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Login (by tenant_id)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login successful', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Save token & tenant', function () {",
                  "    var response = pm.response.json();",
                  "    if (response.data && response.data.token) {",
                  "        pm.collectionVariables.set('token', response.data.token);",
                  "    }",
                  "    if (response.data && response.data.tenant) {",
                  "        pm.collectionVariables.set('tenant_id', response.data.tenant.id);",
                  "        pm.collectionVariables.set('subdomain', response.data.tenant.subdomain);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"admin@cortex.com\",\n    \"password\": \"password123\",\n    \"tenant_id\": {{tenant_id}}\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        },
